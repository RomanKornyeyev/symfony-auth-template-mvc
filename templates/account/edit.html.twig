{% extends 'base.html.twig' %}

{% block title %}Editar cuenta
{% endblock %}

{% block content %}
	<div class="d-flex justify-content-center align-items-center h-100">
		<div class="form-wrapper">
			<h1 class="text-center mb-3">Editar perfil</h1>
			{{ form_start(form, { 'attr': { 'class': 'p-4 p-md-5 border rounded-3 bg-body-tertiary' } }) }}
        {# PROFILE PHOTO #}

        {% include 'partials/account/_avatar_upload.html.twig' with {
          fileField: form.profilePhotoFile,
          removeField: form.removeProfilePhoto,
          initialUrl: asset(app.user.profilePhoto ?: 'media/users/profile_photo/default.jpg'),
          fallbackUrl: asset('media/users/profile_photo/default.jpg'),
          size: 140
        } %}

        {# NICKNAME #}
        <div class="form-floating mb-3">
            {{form_row(form.nickname) }}
        </div>

        {# NAME #}
        <div class="form-floating mb-3">
            {{form_row(form.name) }}
        </div>

        {# DESCRIPTION #}
        <div class="form-floating mb-3">
            {{form_row(form.description) }}
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Guardar</button>
            <a href="{{ path('app_account_index') }}" class="btn btn-outline-primary">Cancelar</a>
        </div>
			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
