{#
  Sección: invitaciones de amistad enviadas pendientes de respuesta.
  Variables: pendingSent (Friendship[]), currentUser (User)
  Solo se renderiza si hay invitaciones enviadas.
#}
{% if pendingSent|length > 0 %}
    <h2 class="h5 mb-3 mt-4">
        <i class="fa-solid fa-paper-plane text-primary me-2"></i>Invitaciones enviadas
        <span class="badge text-bg-primary ms-1">{{ pendingSent|length }}</span>
    </h2>
    <div class="row g-3">
        {% for friendship in pendingSent %}
            {% set receiver = friendship.receiver %}
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card shadow-sm bg-body-tertiary h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <a href="{{ path('app_user_profile', {id: receiver.id}) }}" class="flex-shrink-0">
                            <img src="{{ asset(receiver.profilePhoto) }}"
                                 alt="{{ receiver.nickname }}"
                                 class="rounded-circle border border-2 border-primary border-opacity-50"
                                 style="width:56px;height:56px;object-fit:cover;">
                        </a>
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-semibold text-truncate">
                                <a href="{{ path('app_user_profile', {id: receiver.id}) }}"
                                   class="text-decoration-none text-body">
                                    {{ receiver.nickname }}
                                </a>
                            </div>
                            <div class="text-muted small text-truncate">{{ receiver.name }}</div>
                            <div class="text-muted small">
                                <i class="fa-solid fa-clock me-1 text-primary"></i>
                                Enviada el {{ friendship.createdAt|date('d/m/Y') }}
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div id="friendship-actions-{{ receiver.id }}"
                             data-controller="friendship">
                            {{ include('friendship/_actions_inner.html.twig', {
                                friendship:  friendship,
                                targetUser:  receiver,
                                currentUser: currentUser,
                            }) }}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
